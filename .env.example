# Copy to .env and fill in real values. Never commit .env.
#
# DATABASE_URL is intentionally absent. It is built from the individual password
# variables inside docker-compose.yml so each password has exactly one source of truth.

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme
CENTER_DB_PASSWORD=changeme
MANHWA_DB_PASSWORD=changeme
MEALS_DB_PASSWORD=changeme
PANTRY_DB_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme
REDIS_URL=redis://:changeme@redis:6379

# ── Pocket-ID (v2 required) ───────────────────────────────────────────────────
# Generate: openssl rand -hex 16
POCKET_ID_ENCRYPTION_KEY=

# ── NextAuth (Center) ─────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL=https://lazy.lovey.tv

# ── Pocket-ID OIDC ────────────────────────────────────────────────────────────
# Step 1: start stack, visit https://auth.lazy.lovey.tv, complete first-run.
# Step 2: create OIDC client, redirect URI: https://lazy.lovey.tv/api/auth/callback/pocket-id
# Step 3: fill in below, restart center.
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ISSUER=https://auth.lazy.lovey.tv

# ── JWT signing key for inter-module service tokens ───────────────────────────
# RSA private key (PKCS8 PEM) used to mint and verify inter-module JWTs.
# If unset, a fresh ephemeral key is generated at startup — any in-flight tokens
# are invalidated on Center restart (max 5-min disruption). Set this to survive restarts.
#
# Generate once and store in .env:
#   openssl genrsa 2048 | openssl pkcs8 -topk8 -nocrypt
#
# In .env, wrap the output in double quotes (multiline values are supported):
#   CENTER_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
#   MIIEvQIBADANBgkqhkiG9w0BAQE...
#   -----END PRIVATE KEY-----"
CENTER_JWT_PRIVATE_KEY=

# ── Inter-module ──────────────────────────────────────────────────────────────
CENTER_INTERNAL_URL=http://center:3000

# ── Default users ─────────────────────────────────────────────────────────────
# Used for user-scoped data (reading lists, purchases, etc.) until Caddy
# forward-auth propagates user identity to modules. Set to your Pocket-ID email.
MANHWA_DEFAULT_USER=you@example.com
MEALS_DEFAULT_USER=you@example.com
PANTRY_DEFAULT_USER=you@example.com

# ── Meals module ──────────────────────────────────────────────────────────────
MEALS_RECENT_COOK_DAYS=7

# ── Currency ──────────────────────────────────────────────────────────────────
DEFAULT_CURRENCY=RWF
