# Copy to .env and fill in real values. Never commit .env.

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme
CENTER_DB_PASSWORD=changeme
DATABASE_URL=postgresql://center:changeme@postgres:5432/laziness?options=-csearch_path%3Dcenter

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme
REDIS_URL=redis://:changeme@redis:6379

# ── NextAuth (Center) ─────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL=https://lazy.lovey.tv

# ── Pocket-ID OIDC ────────────────────────────────────────────────────────────
# Step 1: start stack, visit https://auth.lazy.lovey.tv, complete first-run.
# Step 2: create OIDC client, redirect URI: https://lazy.lovey.tv/api/auth/callback/pocket-id
# Step 3: fill in below, restart center.
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ISSUER=https://auth.lazy.lovey.tv

# ── Inter-module ──────────────────────────────────────────────────────────────
CENTER_INTERNAL_URL=http://center:3000

# ── Manhwa module ─────────────────────────────────────────────────────────────
MANHWA_DB_PASSWORD=changeme
MANHWA_DEFAULT_USER=you@example.com

# ── Meals module ──────────────────────────────────────────────────────────────
MEALS_DB_PASSWORD=changeme
# Your email — used for reading list ownership until Caddy forward-auth is wired
MEALS_DEFAULT_USER=you@example.com
# How many days to suppress recently-cooked recipes from suggestions
MEALS_RECENT_COOK_DAYS=7

# ── Pantry module ─────────────────────────────────────────────────────────────
PANTRY_DB_PASSWORD=changeme

# ── Currency ──────────────────────────────────────────────────────────────────
# Default currency for all monetary values. Never assume USD.
# Used as the fallback when no currency is stored alongside a monetary value.
DEFAULT_CURRENCY=RWF
