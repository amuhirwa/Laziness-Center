{
    auto_https off
    servers {
        trusted_proxies static 127.0.0.1
    }
}

http://lazy.lovey.tv {
    @internal path /internal/*
    respond @internal 403

    handle /meals* {
        forward_auth center:3000 {
            uri /api/auth/identify
            copy_headers Remote-Email Remote-Name
        }
        reverse_proxy meals:3000
    }

    handle /pantry* {
        forward_auth center:3000 {
            uri /api/auth/verify
            copy_headers Remote-Email Remote-Name
        }
        reverse_proxy pantry:3000
    }

    handle /us* {
        forward_auth center:3000 {
            uri /api/auth/verify
            copy_headers Remote-Email Remote-Name
        }
        reverse_proxy us:3000
    }

    handle /manhwa* {
        forward_auth center:3000 {
            uri /api/auth/verify
            copy_headers Remote-Email Remote-Name
        }
        uri strip_prefix /manhwa
        reverse_proxy manhwa:8000 {
            header_up X-Forwarded-Proto https
        }
    }

    reverse_proxy center:3000
}

http://auth.lazy.lovey.tv {
    reverse_proxy pocket-id:1411 {
        # Pocket-ID v2 uses X-Forwarded-Proto to compute the WebAuthn RP ID.
        # Without this, Caddy downgrades to "http" and WebAuthn rejects the passkey.
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-Host  {host}
    }
}
