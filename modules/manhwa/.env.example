# Local dev env for the manhwa module.
# Copy to modules/manhwa/.env and source it, or export each var before running uvicorn.
# In production these come from docker-compose.yml — don't commit this file with real values.

DATABASE_URL=postgresql://manhwa:devpassword@localhost:5432/laziness?options=-csearch_path%3Dmanhwa
CENTER_INTERNAL_URL=http://localhost:3000
MANHWA_DEFAULT_USER=you@example.com

# Leave empty in dev — no Caddy prefix-stripping on localhost
MANHWA_ROOT_PATH=
