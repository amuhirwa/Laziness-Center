# Local dev env for the Center.
# Copy to center/.env.local — Next.js loads this automatically in dev.
# Never commit .env.local.

DATABASE_URL=postgresql://center:devpassword@localhost:5432/laziness?options=-csearch_path%3Dcenter
REDIS_URL=redis://:devpassword@localhost:6379

# Any string works locally — doesn't need to be cryptographically strong in dev
AUTH_SECRET=dev-secret-replace-in-production

# Local Pocket-ID (from docker-compose.dev.yml)
NEXTAUTH_URL=http://localhost:3000
OIDC_ISSUER=http://localhost:1411
OIDC_CLIENT_ID=      # fill after Pocket-ID first-run (Step 3 below)
OIDC_CLIENT_SECRET=  # fill after Pocket-ID first-run (Step 3 below)

# Center's own internal URL — localhost:3000 when running natively
CENTER_INTERNAL_URL=http://localhost:3000
